# Copy this file to .env.local and fill in your real values
# Get these from: Shopify Admin -> Apps & settings -> Develop apps -> your app -> API credentials

# Shopify Storefront API Configuration
# The domain of your Shopify store (without https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Shopify Storefront API access token for GraphQL queries
# Must have permissions: read_products, read_collections, read_orders
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_api_token

# Your application's base URL for frontend redirects and links
NEXT_PUBLIC_SITE_URL=http://localhost:3000
